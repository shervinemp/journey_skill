{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Journey Finding",
  "type": "object",
  "required": ["role", "journey", "stepIndex", "step", "location", "visual", "functional", "finding", "severity"],
  "properties": {
    "role": { "type": "string" },
    "journey": { "type": "string" },
    "journeyContext": { "type": "string" },
    "stepIndex": { "type": "integer", "minimum": 0 },
    "step": { "type": "string" },
    "location": { "type": "string" },
    "visual": { "type": "string", "enum": ["Pass", "Fail", "N/A"] },
    "functional": { "type": "string", "enum": ["Pass", "Fail", "N/A"] },
    "finding": { "type": "string" },
    "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "S"] },
    "verifiedBy": { "type": "string", "enum": ["code", "browser", "both", "unverified"] },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
